{
  // Tracker settings
  "tracker_url": "https://example.com",
  "announce_url": "https://example.com/announce/YOUR_ANNOUNCE_KEY",
  "api_key": "YOUR_API_KEY",
  // Tracker login credentials (required for edit.ps1 and delete.ps1)
  "username": "",
  "password": "",

  // Upload defaults
  // Name convention: 1 = UNIT3D format (spaces, normalized), 0 = raw torrent name
  "name_convention": 1,
  "type_id": 3,
  "resolution_id": 2,
  "tmdb": 0,
  "imdb": 0,
  "personal": 0,
  "anonymous": 0,
  "description": "",
  // Subtitle upload defaults (language ID 15 = Bulgarian)
  "subtitle_language_id": 15,

  // TMDB + Google Translate
  "tmdb_api_key": "YOUR_TMDB_API_KEY",
  "google_api_key": "YOUR_GOOGLE_API_KEY",
  "translate_lang": "bg",

  // AI description provider: "gemini" or "ollama"
  "ai_provider": "gemini",
  "gemini_api_key": "YOUR_GEMINI_API_KEY",
  "gemini_model": "gemini-2.5-flash-lite",
  "ollama_model": "gemma3:4b",
  "ollama_url": "",

  // OMDB API (fallback for RT ratings when MDBList has none)
  "omdb_api_key": "YOUR_OMDB_API_KEY",

  // MDBList API (for Rotten Tomatoes ratings, free key from mdblist.com)
  "mdblist_api_key": "YOUR_MDBLIST_API_KEY",

  // Screenshot hosting
  "onlyimage_api_key": "YOUR_ONLYIMAGE_API_KEY"
}
