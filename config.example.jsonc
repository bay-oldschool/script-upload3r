{
    // ─── Tracker ───────────────────────────────────────────────
    "tracker_url": "https://example.com",
    "announce_url": "https://example.com/announce/YOUR_ANNOUNCE_KEY",
    "api_key": "YOUR_API_KEY",
    "username": "",
    "password": "",
    // Base32 TOTP secret for 2FA login (leave empty if 2FA is disabled)
    "two_factor_secret": "",
    // Optional override of the category list used for upload/edit.
    // Relative paths are resolved from the project root. Leave unset to use
    // shared/categories.jsonc. Populate a tracker-specific file with
    // `ps\fetch_categories.ps1` (reads tracker credentials from this config).
    // "categories_file": "shared/categories_example.jsonc",

    // ─── Upload Defaults ───────────────────────────────────────
    // Name convention: 1 = UNIT3D format (spaces, normalized), 0 = raw torrent name
    "name_convention": 1,
    "type_id": 3,
    "resolution_id": 2,
    "tmdb": 0,
    "imdb": 0,
    "personal": 0,
    "anonymous": 0,
    "description": "",
    // Staff-only fields (0 = off, 1 = on, "ask" = prompt on upload)
    "internal": 0,
    "featured": 0,
    "free": 0,
    "fl_until": 0,
    "doubleup": 0,
    "du_until": 0,
    "sticky": 0,
    "mod_queue_opt_in": 0,

    // ─── Subtitle Defaults ─────────────────────────────────────
    // Language ID 15 = Bulgarian
    "subtitle_language_id": 15,

    // ─── TMDB & Google Translate ───────────────────────────────
    "tmdb_api_key": "YOUR_TMDB_API_KEY",
    "google_api_key": "YOUR_GOOGLE_API_KEY",
    "translate_lang": "bg",

    // ─── AI Providers ──────────────────────────────────────────
    // Active provider: "gemini", "ollama", "groq", "grok", "cerebras", "sambanova", "openrouter", or "huggingface"
    "ai_provider": "gemini",

    "gemini_api_key": "YOUR_GEMINI_API_KEY",
    "gemini_model": "gemini-2.5-flash",

    "ollama_model": "gemma3:4b",
    "ollama_url": "",

    "groq_api_key": "YOUR_GROQ_API_KEY",
    "groq_model": "qwen/qwen3-32b",

    "grok_api_key": "YOUR_GROK_API_KEY",
    "grok_model": "grok-3-mini",

    "cerebras_api_key": "YOUR_CEREBRAS_API_KEY",
    "cerebras_model": "llama-3.3-70b",

    "sambanova_api_key": "YOUR_SAMBANOVA_API_KEY",
    "sambanova_model": "Meta-Llama-3.1-70B-Instruct",

    "openrouter_api_key": "YOUR_OPENROUTER_API_KEY",
    "openrouter_model": "qwen/qwen3-32b:free",

    "huggingface_api_key": "YOUR_HUGGINGFACE_API_KEY",
    "huggingface_model": "Qwen/Qwen2.5-72B-Instruct",

    // ─── Ratings APIs ──────────────────────────────────────────
    // MDBList: Rotten Tomatoes ratings (free key from mdblist.com)
    "mdblist_api_key": "YOUR_MDBLIST_API_KEY",
    // OMDB: fallback for RT ratings when MDBList has none
    "omdb_api_key": "YOUR_OMDB_API_KEY",

    // ─── IGDB (Twitch) ────────────────────────────────────────
    // Register at dev.twitch.tv/console
    "twitch_client_id": "YOUR_TWITCH_CLIENT_ID",
    "twitch_client_secret": "YOUR_TWITCH_CLIENT_SECRET",

    // ─── Music Metadata ─────────────────────────────────────────
    // Provider priority order (comma-separated): deezer, musicbrainz, discogs, lastfm, audiodb, itunes
    "music_providers": "deezer,musicbrainz,discogs,lastfm,audiodb,itunes",
    // Discogs personal access token (from discogs.com/settings/developers)
    "discogs_token": "",
    // Last.fm API key (from last.fm/api/account/create)
    "lastfm_api_key": "",
    // TheAudioDB API key (free key: 523532, or get premium from theaudiodb.com)
    "audiodb_api_key": "",

    // ─── Screenshot Hosting ────────────────────────────────────
    "onlyimage_api_key": "YOUR_ONLYIMAGE_API_KEY",

    // ─── Description Templates ────────────────────────────────
    // Paths relative to project root (or absolute). Edit the .bbcode files to customise layout.
    "template_layout_poster": "templates/layout_poster.bbcode",
    "template_layout_no_poster": "templates/layout_no_poster.bbcode",
    "template_fallback_movie": "templates/fallback_movie.bbcode",
    "template_screenshots": "templates/screenshots.bbcode",
    // ASCII logo injected into generated NFOs ({{LOGO}} placeholder in shared/default.nfo). Relative to script dir or absolute.
    "nfo_logo_path": "shared/logo_ascii.txt",

    // ─── UI Settings ───────────────────────────────────────────
    // Show ASCII logo in main menu: 1 = show, 0 = hide
    "show_logo": 1,
    // Logo source: "text" = colored ASCII from logo.txt, "image" = render logo.png
    "logo_source": "image",
    // Path to image used by "image" source (relative to script dir or absolute). Falls back to shared/logo.png if unset or missing.
    "logo_image_path": "shared/logo.png",
    // Display mode for "image" source: "ansi" = half-blocks, "block" = shade chars (░▒▓█), "ascii" = ASCII chars, "direct" = Sixel
    "logo_display": "direct",
    // Logo width in characters (all image display modes)
    "logo_width": 40,
    // Logo colors (256-color codes, "text" source only): letters, dark shading, light shading
    "logo_color_letters": 160,
    "logo_color_dark": 210,
    "logo_color_light": 95
}
