{
  // Tracker settings
  "tracker_url": "https://example.com",
  "announce_url": "https://example.com/announce/YOUR_ANNOUNCE_KEY",
  "api_key": "YOUR_API_KEY",
  // Tracker login credentials (required for edit.sh/ps1 and delete.sh/ps1)
  "username": "",
  "password": "",

  // Upload defaults
  "type_id": 3,
  "resolution_id": 2,
  "tmdb": 0,
  "imdb": 0,
  "personal": 0,
  "anonymous": 0,
  "description": "",

  // TMDB + Google Translate
  "tmdb_api_key": "YOUR_TMDB_API_KEY",
  "google_api_key": "YOUR_GOOGLE_API_KEY",
  "translate_lang": "bg",

  // AI description provider: "gemini" or "ollama"
  "ai_provider": "gemini",
  "gemini_api_key": "YOUR_GEMINI_API_KEY",
  "gemini_model": "gemini-2.5-flash-lite",
  "ollama_model": "gemma3:4b",
  "ollama_url": "",

  // OMDB API (for Rotten Tomatoes rating, free key from omdbapi.com)
  "omdb_api_key": "YOUR_OMDB_API_KEY",

  // Screenshot hosting
  "onlyimage_api_key": "YOUR_ONLYIMAGE_API_KEY"
}
